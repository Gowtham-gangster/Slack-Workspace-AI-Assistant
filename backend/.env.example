PORT=3001
NODE_ENV=development

# JWT Secret — use a long, random string (at least 64 characters) in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# Allowed CORS origins (comma-separated) — only needed in production
# Example: ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com
ALLOWED_ORIGINS=

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_DB_PASSWORD
MYSQL_DATABASE=slack_ai_assistant

# Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
